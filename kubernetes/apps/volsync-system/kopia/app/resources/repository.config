{
  "storage": {
    "type": "s3",
    "config": {
      "bucket": "{{ .KOPIA_REPOSITORY }}",
      "endpoint": "https://{{ .CLOUDFLARE_ACCOUNT_ID }}.r2.cloudflarestorage.com",
      "accessKeyID": "{{ .AWS_ACCESS_KEY_ID }}",
      "secretAccessKey": "{{ .AWS_SECRET_ACCESS_KEY }}"
    }
  },
  "hostname": "volsync.volsync-system.svc.cluster.local",
  "username": "volsync",
  "description": "volsync",
  "enableActions": false
}
